{
    "compilerOptions": {
      "target": "es2017",
      "module": "esnext",
      "moduleResolution": "node",
      "declaration": true,
      "outDir": "./types",
      "downlevelIteration": true,
      "strict": true,
      "strictPropertyInitialization": false,
      "typeRoots": [
        "node_modules/@types",
        "src/typings"
      ],
      "baseUrl": ".",
      "rootDirs": ["./src"],
      "paths": {
        "*": ["node_modules/*"],
        "~/*": ["src/*"]
      }
    },
    "include": ["src/index.ts", "src/typings/**/*.d.ts"],
    "exclude": ["node_modules", "**/__tests__/*", "test"]
  }
